# Base de datos (asyncpg; también acepta postgresql:// y se convierte automáticamente)
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/thorax_db

# JWT / autenticación
SECRET_KEY=change-me-to-a-long-random-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Gemini API (recomendaciones médicas)
GEMINI_API_KEY=

# Correo (envío de reportes PDF)
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=
MAIL_PORT=587
MAIL_SERVER=
MAIL_STARTTLS=true
MAIL_SSL_TLS=false

# Servidor
APP_HOST=127.0.0.1
APP_PORT=8000
APP_DEBUG=true

# CORS (orígenes separados por coma)
BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Almacenamiento y modelos IA
UPLOAD_DIR=uploads
MODEL_LR_PATH=models_ia/modelo_lr.joblib
MODEL_RF_PATH=models_ia/modelo_rf.joblib
